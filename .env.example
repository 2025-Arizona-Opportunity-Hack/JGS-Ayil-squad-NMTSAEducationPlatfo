# ===========================================
# NMTSA Education Platform - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Required variables are marked with [REQUIRED].
# Optional variables are marked with [OPTIONAL].

# --- Convex Backend [REQUIRED] ---
# Get these from https://dashboard.convex.dev after creating a project
CONVEX_DEPLOYMENT=dev:your-deployment-name
VITE_CONVEX_URL=https://your-deployment-name.convex.cloud

# --- Google OAuth [OPTIONAL - enables "Sign in with Google"] ---
# Create at https://console.cloud.google.com/apis/credentials
# See README.md for full setup instructions
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# --- Google Drive Integration [OPTIONAL - enables file import from Drive] ---
# Uses same Google Cloud project as OAuth above
# See README.md "Google Drive Integration" section for setup
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your-google-api-key
VITE_GOOGLE_APP_ID=your-project-number

# --- Stripe Payments [OPTIONAL - enables paid content purchases] ---
# Create at https://dashboard.stripe.com/apikeys
# STRIPE_WEBHOOK_SECRET is REQUIRED if STRIPE_SECRET_KEY is set (security requirement)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# --- Email via Resend [OPTIONAL - enables email notifications] ---
# Create at https://resend.com
# RESEND_DOMAIN should match your verified sending domain
RESEND_DOMAIN=your-domain.com

# --- SMS via Twilio [OPTIONAL - enables SMS notifications] ---
# Create at https://console.twilio.com
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# --- Production Settings [REQUIRED for deployment] ---
# Your production frontend URL (used for CORS, email links, share links)
SITE_URL=https://your-production-domain.com
# Set to "production" to enable production behaviors
ENVIRONMENT=production
